void countDownFrom(int num) // Định nghĩa hàm đếm ngược
{
    if (num >= 0)
    {                           // Điều kiện tiếp tục đệ quy (chưa tới 0)
        cout << num << endl;    // In số hiện tại
        countDownFrom(num - 1); // Gọi lại chính nó với giá trị giảm đi 1
    }
} // end countDownFrom

int sumValues(int num) // Định nghĩa hàm tính tổng đệ quy
{
    if (num > 1)
    {                                    // Điều kiện tiếp tục đệ quy (lớn hơn 1)
        return num + sumValues(num - 1); // Trả về số hiện tại cộng với tổng của số nhỏ hơn
    }
    return 0; // Dừng đệ quy (Base case) khi num = 1 hoặc nhỏ hơn, trả về 0 hoặc num
}

